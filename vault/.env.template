# ─────────────────────────────────────────────────────────────────────────────
# Maaya / Vault — Secrets Template
# Copy this to .env and fill in your real credentials.
# .env is gitignored and will never be committed.
# ─────────────────────────────────────────────────────────────────────────────

# Plaid environment: sandbox | development | production
# → Use "development" for real bank accounts (up to 100 linked items, free)
# → Use "production" for unlimited (requires Plaid approval)
PLAID_ENV=development

# Your Plaid Client ID — same across all environments
# Get it from: https://dashboard.plaid.com → Team Settings → Keys
PLAID_CLIENT_ID=your_client_id_here

# Your Plaid Secret for the environment chosen above
# Each environment (sandbox / development / production) has a different secret
PLAID_API_KEY=your_development_secret_here
